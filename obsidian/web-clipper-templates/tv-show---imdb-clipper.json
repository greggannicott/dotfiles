{
	"schemaVersion": "0.1.0",
	"name": "TV Show - IMDB",
	"behavior": "create",
	"noteContentFormat": "# Synopsis\n\n{{schema:@TVSeries:description}}\n",
	"properties": [
		{
			"name": "categories",
			"value": "[[Show]]",
			"type": "multitext"
		},
		{
			"name": "type",
			"value": "[[TV Show]]",
			"type": "multitext"
		},
		{
			"name": "year",
			"value": "{{schema:@TVSeries:datePublished|date:\\\"YYYY\\\"}}",
			"type": "number"
		},
		{
			"name": "genre",
			"value": "{{schema:@TVSeries:genre}}",
			"type": "multitext"
		},
		{
			"name": "actors",
			"value": "{{schema:@TVSeries:actor|map:a => a.name|map:a => \\\"${a}\\\"|map:a => a.str|wikilink|join}}",
			"type": "multitext"
		},
		{
			"name": "cover",
			"value": "{{image}}",
			"type": "text"
		},
		{
			"name": "episodes",
			"value": "{{selector:[data-testid=\\\"hero-subnav-bar-series-episode-count\\\"]|trim}}",
			"type": "number"
		},
		{
			"name": "aliases",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "tags",
			"value": "inbox",
			"type": "multitext"
		},
		{
			"name": "rating",
			"value": "",
			"type": "number"
		},
		{
			"name": "imdb-rating",
			"value": "{{schema:@TVSeries:aggregateRating.ratingValue}}",
			"type": "text"
		},
		{
			"name": "watched",
			"value": "",
			"type": "checkbox"
		},
		{
			"name": "to-watch",
			"value": "",
			"type": "checkbox"
		},
		{
			"name": "reason-comment",
			"value": "",
			"type": "text"
		},
		{
			"name": "reason-links",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "imdb-url",
			"value": "{{url}}",
			"type": "text"
		},
		{
			"name": "channel",
			"value": "",
			"type": "text"
		},
		{
			"name": "topics",
			"value": "",
			"type": "multitext"
		}
	],
	"triggers": [
		"schema:@TVSeries"
	],
	"noteNameFormat": "{{schema:@TVSeries:name}}",
	"path": "References/"
}