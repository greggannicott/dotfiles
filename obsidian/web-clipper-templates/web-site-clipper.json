{
	"schemaVersion": "0.1.0",
	"name": "Web Site",
	"behavior": "create",
	"noteContentFormat": "",
	"properties": [
		{
			"name": "categories",
			"value": "[[Web Site]]",
			"type": "multitext"
		},
		{
			"name": "url",
			"value": "{{domain}}",
			"type": "text"
		},
		{
			"name": "authors",
			"value": "{{author|map:a => a|map:a => \\\"${a}\\\"|map:a => a.str|wikilink|join}}",
			"type": "multitext"
		},
		{
			"name": "topics",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "aliases",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "tags",
			"value": "inbox",
			"type": "multitext"
		}
	],
	"triggers": [],
	"noteNameFormat": "{{site}}",
	"path": "References/"
}