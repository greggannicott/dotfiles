{
	"schemaVersion": "0.1.0",
	"name": "Album - Release - Discogs",
	"behavior": "create",
	"noteContentFormat": "# Songs\n\n![[Songs On Music Release.base]]\n",
	"properties": [
		{
			"name": "categories",
			"value": "[[Music Release]]",
			"type": "multitext"
		},
		{
			"name": "type",
			"value": "[[Album]]",
			"type": "multitext"
		},
		{
			"name": "aliases",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "artists",
			"value": "{{schema:@MusicRelease:releaseOf.byArtist|map:a => a.name|map:item => \\\"${item}\\\"|wikilink|join}}",
			"type": "multitext"
		},
		{
			"name": "cover",
			"value": "{{image}}",
			"type": "text"
		},
		{
			"name": "genres",
			"value": "{{schema:@MusicRelease:genre|map:a => a|map:a => \\\"${a}\\\"|map:a => a.str|wikilink|join}}",
			"type": "multitext"
		},
		{
			"name": "year",
			"value": "{{schema:@MusicRelease:datePublished}}",
			"type": "number"
		},
		{
			"name": "discogs-id",
			"value": "{{schema:@MusicRelease:@id}}",
			"type": "text"
		},
		{
			"name": "reason-comment",
			"value": "",
			"type": "text"
		},
		{
			"name": "reason-links",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "track-count",
			"value": "{{schema:@MusicRelease:numTracks}}",
			"type": "number"
		},
		{
			"name": "owned",
			"value": "",
			"type": "checkbox"
		},
		{
			"name": "rating",
			"value": "",
			"type": "number"
		},
		{
			"name": "tags",
			"value": "inbox",
			"type": "multitext"
		},
		{
			"name": "input-source",
			"value": "obsidian-web-clipper-discogs",
			"type": "text"
		},
		{
			"name": "to-buy",
			"value": "",
			"type": "checkbox"
		},
		{
			"name": "buy-from",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "in-rotation",
			"value": "",
			"type": "checkbox"
		}
	],
	"triggers": [
		"schema:@MusicRelease"
	],
	"noteNameFormat": "{{schema:@MusicRelease:name}}",
	"path": "References/"
}