{
	"schemaVersion": "0.1.0",
	"name": "YouTube Video",
	"behavior": "create",
	"noteContentFormat": "# Description\n\n{{schema:@VideoObject:description}}\n",
	"properties": [
		{
			"name": "author",
			"value": "[[{{schema:@VideoObject:author}}]]",
			"type": "multitext"
		},
		{
			"name": "categories",
			"value": "[[Clipping]]",
			"type": "multitext"
		},
		{
			"name": "type",
			"value": "[[Video]]",
			"type": "multitext"
		},
		{
			"name": "genre",
			"value": "{{schema:@VideoObject:genre}}",
			"type": "multitext"
		},
		{
			"name": "cover",
			"value": "{{schema:@VideoObject:thumbnailUrl}}",
			"type": "text"
		},
		{
			"name": "uploadDate",
			"value": "{{schema:@VideoObject:uploadDate}}",
			"type": "text"
		},
		{
			"name": "duration",
			"value": "{{schema:@VideoObject:duration}}",
			"type": "text"
		},
		{
			"name": "url",
			"value": "{{schema:@VideoObject:@id}}",
			"type": "text"
		},
		{
			"name": "topics",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "tags",
			"value": "inbox",
			"type": "multitext"
		}
	],
	"triggers": [
		"schema:@VideoObject"
	],
	"noteNameFormat": "{{title}}",
	"path": "Clippings/"
}