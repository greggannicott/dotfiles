{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "ask",
    "bash": {
      "find": "allow",
      "wc": "allow",
      "tail": "allow",
    },
    "webfetch": "allow",
  },
  "mcp": {
    "chrome": {
      "type": "local",
      "command": ["npx", "chrome-devtools-mcp@latest", "--autoConnect"],
      "enabled": false,
    },
    "readwise": {
      "type": "remote",
      "url": "https://mcp2.readwise.io/mcp",
      "enabled": false,
    },
  },
}
